%%%% Exempel på entryn från DiVA.
%%%% Här är url-fältet tillagt, "UX" i titeln lagt inom {} för att det inte ska bli lowercase, och space före kolon som separerar titel från undertitel borttaget i titeln.
@mastersthesis{Brane973772,
   author = {Br{\"a}ne, Arvid},
   institution = {Umeå University, Department of Applied Physics and Electronics},
   pages = {65},
   school = {Umeå University, Department of Applied Physics and Electronics},
   title = {User Experience Design for Children: Developing and Testing a {UX} Framework},
   keywords = {user experience (UX), user interface (UI), interaction design (IxD), graphical user interface (GUI), design, usability, kids, children, minors, teenagers, childhood, guidelines, framework, child centered design (CCD), tablets, smartphones, media, Lego, Star Wars, North Kingdom},
   abstract = {Designing good digital experiences for children can be difficult; designers have to consider children's cognitive and motor skill limitations, understand their target audience, create something entertaining and educational, comply with national and international jurisdiction, and at the same time appeal to parents. We set out to create a general framework which designers and developers can use as a foundation and testing ground for their digital products in the field of user experience. The methods used during the thesis include interviews, literature studies, user testing, case studies, personas, prototyping, and more. The results created are primarily user experience guidelines packaged in a Theoretical Framework, user testing conclusions, along with suggestions on improving the current Lego Star Wars: Force Builders application, a few in the form of prototypes. },
   year = {2016},
   url = {http://urn.kb.se/resolve?urn=urn:nbn:se:umu:diva-125935}
}

%%%% Här är entrytypen ändrad från misc till techreport, fältet "series" ändrat till "type", url-fältet tillagt,
%%%% och "DreamScape" i titeln lagd inom {} för att bevara CamelCaps.
%%%% Av någon anledning lägger DiVA in flera "school"-fält. Ta bort de extra om varningarna stör.
@techreport{Alstergren1439802,
   author = {Alstergren, Iza and Andersson, Andreas and Hedman, Lovisa and Maric, Daniela},
   institution = {Uppsala University, Department of Information Technology},
   pages = {41},
   school = {Uppsala University, Department of Information Technology},
   school = {Uppsala University, Department of Information Technology},
   school = {Uppsala University, Department of Information Technology},
   school = {Uppsala University, Department of Information Technology},
   title = {{DreamScape}, a Platform for Creating, Sharing and Listening to Interactive Stories},
   type = {Självständigt arbete i informationsteknologi},
   number = {2020-007},
   abstract = {Storytelling has been a part of human culture ever since we gained the ability to speak. Telling stories is a way to entertain, pass along knowledge, and present moral dilemmas. Today, many people choose to enjoy stories by listening to audiobooks. With a technique called gamification, engagement in storytelling can be increased by adding certain game elements. In this report DreamScape is presented. DreamScape was created to make it easy for people to create, share, and engage in storytelling. On the DreamScape web application, users can create multiple choice stories that can have different endings. The stories are listened to on the accompanying mobile application were users can control the course of the story through voice commands. A level of gamification was added in the aspects of meaningful choice and the user being able to explore the different outcomes of the stories. When evaluating DreamScape with user tests, some participants had difficulties creating or listening to a story. This indicated that the user-friendliness could be improved. Despite this, they managed to create and listen to a story proving that our goal of creating a storytelling platform was achieved. },
   year = {2020},
   url = {http://urn.kb.se/resolve?urn=urn:nbn:se:uu:diva-413015}
}


